# Production defaults for esp-lightning-mqtt
# Generated for ESP32-C3 / ESP-IDF v5.x

# Logging: INFO level in production
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_DEFAULT_LEVEL=3

# Optimise for size
CONFIG_COMPILER_OPTIMIZATION_SIZE=y

# PSRAM: not present on bare ESP32-C3
CONFIG_SPIRAM=n

# FreeRTOS tick rate
CONFIG_FREERTOS_HZ=1000

# MQTT component
CONFIG_MQTT_PROTOCOL_311=y
CONFIG_MQTT_TRANSPORT_TCP=y

# NVS
CONFIG_NVS_ENCRYPTION=n

# Wi-Fi
CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=4
CONFIG_ESP_WIFI_DYNAMIC_RX_BUFFER_NUM=8

# --- Project settings (override via idf.py menuconfig) ---
CONFIG_WIFI_SSID="myssid"
CONFIG_WIFI_PASSWORD="mypassword"
CONFIG_MQTT_BROKER_URL="mqtt://192.168.1.10:1883"
CONFIG_MQTT_USERNAME=""
CONFIG_MQTT_PASSWORD=""
CONFIG_MQTT_BASE_TOPIC="esp-lightning-mqtt"
CONFIG_AS3935_I2C_ADDR=0x03
CONFIG_AS3935_I2C_PORT=0
CONFIG_AS3935_SDA_GPIO=6
CONFIG_AS3935_SCL_GPIO=7
CONFIG_AS3935_IRQ_GPIO=4
CONFIG_AS3935_INDOOR_MODE=y
